# Frontend no longer needs GEMINI_API_KEY in local env.
# Gemini API keys are saved per guest session via /api/user-settings/api-key.

# Cloudflare secret required in production/pages functions:
# MASTER_SECRET="use-a-random-secret-with-at-least-32-characters"
# GEMINI_PROCESSOR_URL="https://your-cloud-run-service.run.app"
# PROCESSOR_SHARED_SECRET="use-a-second-random-secret-for-cloudflare-to-cloud-run-calls"

# Cloud Run env required:
# PROCESSOR_SHARED_SECRET="must-match-cloudflare-secret"
